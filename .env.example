# Copy to .env and fill in only what you need. Everything runs WITHOUT these.

# --- LLM (optional): enables LLM-written prose AND the LLM planner ---
ANTHROPIC_API_KEY=
ALPHAFORGE_LLM_MODEL=claude-sonnet-4-6

# --- Database (optional): default is local SQLite; set this for Postgres ---
# DATABASE_URL=postgresql://alphaforge:alphaforge@localhost:5432/alphaforge
# ALPHAFORGE_DB=alphaforge.db      # SQLite file location

# --- Cache (optional): default is in-memory; set this for Redis ---
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=3600

# --- Live data (optional) ---
# SEC_USER_AGENT=Your Name your@email.com   # required by SEC EDGAR for --edgar

# --- Nightly automation / alerts (optional) ---
# WATCHLIST=NVDA,AMD,TSM,ASML,MU,INTC
# ALERT_VAR_PCT=4.0          # fire if a name's 1-day 95% VaR exceeds this
# ALERT_DOWNSIDE=-20         # fire if DCF implies downside worse than this %
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ALERT_FROM=
# ALERT_TO=
